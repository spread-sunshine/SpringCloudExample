<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.template</groupId>
    <artifactId>spring-cloud-microservice-template</artifactId>
    <version>2.0.0</version>
    <packaging>pom</packaging>

    <name>Spring Cloud Microservice Template</name>
    <description>
        Multi-module microservice template: service (Servlet+JPA) + gateway (WebFlux).
        Architecture follows the industry best practice of separating Gateway (reactive)
        from business services (servlet).
        Built on Spring Boot 4 with Java 21 Leyden AOT support.
    </description>

    <!-- ========== Submodules ========== -->
    <modules>
        <module>service</module>
        <module>gateway</module>
    </modules>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.0.0</version>
        <relativePath/>
    </parent>

    <properties>
        <!-- Java 21 required for Spring Boot 4 + Leyden -->
        <java.version>21</java.version>
        <!-- Spring Cloud 2025.0 (Northfields) supports Spring Boot 4 -->
        <spring-cloud.version>2025.0</spring-cloud.version>
        <lombok.version>1.18.34</lombok.version>
        <testcontainers.version>1.20.2</testcontainers.version>
        <springdoc.version>2.7.0</springdoc.version>
        <maven.compiler.source>${java.version}</maven.compiler.source>
        <maven.compiler.target>${java.version}</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <!-- Leyden / AOT Properties -->
        <spring-boot.processing.aot.enabled>true</spring-boot.processing.aot.enabled>
        <spring-boot.processing.aot.graceful-shutdown>true</spring-boot.processing.aot.graceful-shutdown>
    </properties>

    <!-- ========== Dependency Management (BOM) ========== -->
    <dependencyManagement>
        <dependencies>
            <!-- Spring Cloud BOM -->
            <dependency>
                <groupId>org.springframework.cloud</groupId>
                <artifactId>spring-cloud-dependencies</artifactId>
                <version>${spring-cloud.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <!-- ========== Repositories ========== -->
    <!--
      Spring Boot 4 + Spring Cloud 2025.0 may not be available on all mirrors.
      Multiple repositories added for maximum availability.
    -->
    <repositories>
        <repository>
            <id>aliyun</id>
            <name>Aliyun Public</name>
            <url>https://maven.aliyun.com/repository/public</url>
        </repository>
        <repository>
            <id>spring-milestones</id>
            <name>Spring Milestones</name>
            <url>https://repo.spring.io/milestone</url>
            <snapshots>
                <enabled>false</enabled>
            </snapshots>
        </repository>
        <repository>
            <id>maven-central</id>
            <name>Maven Central</name>
            <url>https://repo1.maven.org/maven2/</url>
        </repository>
    </repositories>
    <pluginRepositories>
        <pluginRepository>
            <id>aliyun</id>
            <name>Aliyun Public</name>
            <url>https://maven.aliyun.com/repository/public</url>
        </pluginRepository>
        <pluginRepository>
            <id>spring-milestones</id>
            <name>Spring Milestones</name>
            <url>https://repo.spring.io/milestone</url>
            <snapshots>
                <enabled>false</enabled>
            </snapshots>
        </pluginRepository>
        <pluginRepository>
            <id>maven-central</id>
            <name>Maven Central</name>
            <url>https://repo1.maven.org/maven2/</url>
        </pluginRepository>
    </pluginRepositories>

    <!-- ========== Build Plugin Management ========== -->
    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-maven-plugin</artifactId>
                    <configuration>
                        <excludes>
                            <exclude>
                                <groupId>org.projectlombok</groupId>
                                <artifactId>lombok</artifactId>
                            </exclude>
                        </excludes>
                        <!-- Leyden: enable AOT processing for faster startup -->
                        <image>
                            <builder>docker.io/paketobuildpacks/builder-jammy-base</builder>
                            <env>
                                <BP_NATIVE_IMAGE>true</BP_NATIVE_IMAGE>
                            </env>
                            <!--
                            Leyden Condensed Lock Mode:
                            Use -XX:CondensedLockMode=on at runtime for
                            reduced memory footprint and faster lock acquisition.
                            This is a JDK 21+ Leyden preview feature.
                            -->
                        </image>
                        <executions>
                            <!--
                            Leyden AOT processing execution:
                            Generates AOT-optimized classes at build time,
                            dramatically reducing application startup time.
                            -->
                            <execution>
                                <id>process-aot</id>
                                <goals>
                                    <goal>process-aot</goal>
                                </goals>
                            </execution>
                        </executions>
                    </configuration>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <configuration>
                        <annotationProcessorPaths>
                            <path>
                                <groupId>org.projectlombok</groupId>
                                <artifactId>lombok</artifactId>
                                <version>${lombok.version}</version>
                            </path>
                        </annotationProcessorPaths>
                        <source>${java.version}</source>
                        <target>${java.version}</target>
                        <!-- Leyden: Enable preview features for Condensed Lock Mode -->
                        <compilerArgs>
                            <arg>--enable-preview</arg>
                        </compilerArgs>
                    </configuration>
                </plugin>
            </plugins>
        </pluginManagement>
    </build>

    <!-- ========== Profiles ========== -->
    <profiles>
        <profile>
            <id>dev</id>
            <properties>
                <spring.profiles.active>dev</spring.profiles.active>
            </properties>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
        </profile>
        <profile>
            <id>prod</id>
            <properties>
                <spring.profiles.active>prod</spring.profiles.active>
            </properties>
        </profile>
        <!--
        Leyden Profile: Enables full AOT + native image compilation.
        Usage: mvn clean package -Pleyden
        Requires: GraalVM 25+ or JDK with Leyden support
        -->
        <profile>
            <id>leyden</id>
            <properties>
                <spring-boot.processing.aot.enabled>true</spring-boot.processing.aot.enabled>
                <spring-boot.processing.aot.mode>native</spring-boot.processing.aot.mode>
            </properties>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.springframework.boot</groupId>
                        <artifactId>spring-boot-maven-plugin</artifactId>
                        <executions>
                            <execution>
                                <id>package-native-image</id>
                                <phase>package</phase>
                                <goals>
                                    <goal>build-image</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
